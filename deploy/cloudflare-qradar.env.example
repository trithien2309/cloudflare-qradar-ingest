# Copy this file to /opt/cloudflare-qradar/cloudflare-qradar.env
# then fill in the real values on the QRadar server.

CF_ACCOUNT_ID="your_account_id"
CF_ZONE_ID="your_zone_id"
CF_API_TOKEN="your_api_token"

QRADAR_SYSLOG_HOST="127.0.0.1"
QRADAR_SYSLOG_PORT="514"
QRADAR_SYSLOG_HOSTNAME="cf-qradar-collector"
